NODE_ENV=development
PORT=3000

# PostgreSQL
POSTGRES_PASSWORD=flowdesk
DATABASE_URL=postgresql://flowdesk:flowdesk@localhost:5432/flowdesk?schema=public

# Redis
REDIS_URL=redis://redis:6379

# JWT — change this in production (min 32 chars)
# This default placeholder is REJECTED in production by env.ts KNOWN_DEFAULTS check.
JWT_SECRET=change-me-to-a-32-char-random-string-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting / proxy
# Set to 1+ when behind nginx/Cloudflare. 0 = do not trust X-Forwarded-For.
TRUST_PROXY_HOPS=0
# SKIP_RATE_LIMIT only works in non-production (no effect in production).
# SKIP_RATE_LIMIT=0

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# LLM (OpenAI-compatible)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# Uploads
UPLOAD_DIR=/data/attachments
MAX_UPLOAD_SIZE=26214400

# Logging
LOG_LEVEL=info

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_PASSWORD=smtp-password-goes-here