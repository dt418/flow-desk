NODE_ENV=development
PORT=3000

# PostgreSQL
POSTGRES_PASSWORD=flowdesk
DATABASE_URL=postgresql://flowdesk:flowdesk@localhost:5432/flowdesk?schema=public

# Optional multi-replica pooler (compose profile: pgbouncer) — see docs/DEPLOY.md §5
# docker compose --profile pgbouncer up -d
# DB_HOST=pgbouncer
# DB_PORT=5432
# PG_POOL_MAX=5
# PGBOUNCER_PORT=6432
# Host migrate still uses direct Postgres (localhost:5432 / postgres:5432), not PgBouncer.

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# JWT — change this in production (min 32 chars)
# This default placeholder is REJECTED in production by env.ts KNOWN_DEFAULTS check.
JWT_SECRET=change-me-to-a-32-char-random-string-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Public app URL used in email links and absolute redirects
APP_URL=http://localhost:3000

# Rate limiting / proxy
# Set to 1+ when behind nginx/Cloudflare. 0 = do not trust X-Forwarded-For.
TRUST_PROXY_HOPS=0
# SKIP_RATE_LIMIT only works in non-production (no effect in production).
# SKIP_RATE_LIMIT=0

# Ops
# Production: GET /metrics returns 503 until METRICS_TOKEN is set (min 16 chars).
# With token set (any env), scrapers must send: Authorization: Bearer <token>.
# Local/test: leave empty for open scrape.
# Generate: openssl rand -hex 16
METRICS_TOKEN=
# Recommended in production — unhandled errors reported to Sentry.
# Example: https://<key>@o0.ingest.sentry.io/<project>
SENTRY_DSN=

# Optional Redis AUTH (set both; see docs/DEPLOY.md)
# REDIS_PASSWORD=
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# GitHub OAuth (optional)
# FLOWDESK_GITHUB_CLIENT_ID=
# FLOWDESK_GITHUB_CLIENT_SECRET=
# FLOWDESK_GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# P4-3 Slack OAuth (optional)
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_REDIRECT_URI=http://localhost:3000/api/integrations/slack/callback

# P4-3 GitLab OAuth (optional)
# FLOWDESK_GITLAB_CLIENT_ID=
# FLOWDESK_GITLAB_CLIENT_SECRET=
# FLOWDESK_GITLAB_REDIRECT_URI=http://localhost:3000/api/integrations/gitlab/callback

# LLM (OpenAI-compatible) — required; placeholders like sk-placeholder are rejected by env schema
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-real-key-here
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# Outbound webhooks: set to 1 only if self-hosted receivers need RFC1918 private IPs.
# Always blocked (even when private allowed): loopback, 169.254.0.0/16, AWS IMDS IPv6 fd00:ec2::/32.
# When private disallowed (default): also blocks RFC1918, CGNAT 100.64/10, ULA fc00::/7.
# ALLOW_PRIVATE_WEBHOOK_URLS=0

# Uploads
UPLOAD_DIR=/data/attachments
MAX_UPLOAD_SIZE=26214400

# Logging
LOG_LEVEL=info

# Email
EMAIL_PROVIDER=nodemailer
EMAIL_FROM=FlowDesk <noreply@flowdesk.local>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=smtp-password-goes-here
# RESEND_API_KEY=