{
  "name": "flow-desk",
  "version": "0.1.0",
  "private": true,
  "description": "FlowDesk — self-hosted AI-augmented task management",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate --filter=@flow-desk/api",
    "db:migrate": "turbo run db:migrate --filter=@flow-desk/api",
    "db:migrate-deploy": "turbo run db:migrate-deploy --filter=@flow-desk/api",
    "db:seed": "turbo run db:seed --filter=@flow-desk/api",
    "db:push": "turbo run db:push --filter=@flow-desk/api",
    "db:push-skip-generate": "turbo run db:push-skip-generate --filter=@flow-desk/api",
    "db:studio": "turbo run db:studio --filter=@flow-desk/api",
    "db:reset": "turbo run db:reset --filter=@flow-desk/api",
    "stack:up": "bash scripts/docker-up.sh up",
    "stack:up-build": "bash scripts/docker-up.sh up --build",
    "stack:down": "bash scripts/docker-up.sh down",
    "stack:logs": "bash scripts/docker-up.sh logs",
    "stack:ps": "bash scripts/docker-up.sh ps",
    "stack:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "stack:dev-build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build",
    "stack:dev-down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "dev:local": "bash scripts/dev-local.sh",
    "prisma": "bash scripts/prisma-exec.sh",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\"",
    "setup:hooks": "lefthook install && echo 'lefthook installed (managed via lefthook.yml)'",
    "setup:lefthook": "lefthook install && echo 'lefthook installed (managed via lefthook.yml)'",
    "check:secrets": ".githooks/pre-commit",
    "guardrails": "bash scripts/guardrails.sh",
    "verify": "lefthook run pre-commit && lefthook run pre-push",
    "ship": "bash scripts/ship.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.3.3",
    "tsx": "^4.22.4",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.62.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1"
  }
}
