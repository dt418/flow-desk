{
  "name": "flow-desk",
  "version": "0.1.0",
  "private": true,
  "description": "FlowDesk — self-hosted AI-augmented task management",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate --filter=@flow-desk/api",
    "db:migrate": "turbo run db:migrate --filter=@flow-desk/api",
    "db:migrate-deploy": "turbo run db:migrate-deploy --filter=@flow-desk/api",
    "db:seed": "turbo run db:seed --filter=@flow-desk/api",
    "db:push": "turbo run db:push --filter=@flow-desk/api",
    "db:push-skip-generate": "turbo run db:push-skip-generate --filter=@flow-desk/api",
    "db:studio": "turbo run db:studio --filter=@flow-desk/api",
    "db:reset": "turbo run db:reset --filter=@flow-desk/api",
    "stack:up": "bash scripts/docker-up.sh up",
    "stack:up-build": "bash scripts/docker-up.sh up --build",
    "stack:down": "bash scripts/docker-up.sh down",
    "stack:logs": "bash scripts/docker-up.sh logs",
    "stack:ps": "bash scripts/docker-up.sh ps",
    "dev:local": "bash scripts/dev-local.sh",
    "prisma": "bash scripts/prisma-exec.sh",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\"",
    "setup:hooks": "git config core.hooksPath .githooks && echo \"Git hooks installed (path: .githooks)\" && ls -la .githooks/",
    "check:secrets": ".githooks/pre-commit"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2"
  }
}