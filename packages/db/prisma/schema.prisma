// FlowDesk Prisma schema
// Soft-delete on User, Workspace, Task, Comment, Attachment via deletedAt

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum WorkspaceVisibility {
  PRIVATE
  PUBLIC
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_MENTIONED
  TASK_DUE_SOON
  TASK_OVERDUE
  TASK_COMPLETED
  COMMENT_REPLY
  WORKSPACE_INVITE
  WORKSPACE_ROLE_CHANGED
}

enum AttachmentType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  OTHER
}

enum ActivityAction {
  CREATED
  TITLE_CHANGED
  DESCRIPTION_CHANGED
  STATUS_CHANGED
  PRIORITY_CHANGED
  COLUMN_CHANGED
  ASSIGNEE_CHANGED
  DUE_DATE_CHANGED
  MOVED
  RESTORED
  SUBTASK_CREATED
  DEPENDENCY_CREATED
  DEPENDENCY_DELETED
  COMMENT_ADDED
  LABEL_ADDED
  LABEL_REMOVED
}

model User {
  id                    String   @id @default(cuid())
  email                 String   @unique
  name                  String
  avatarUrl             String?
  passwordHash          String?
  twoFactorEnabled      Boolean  @default(false)
  /// AES-256-GCM ciphertext of TOTP secret (base64: iv.tag.ciphertext) — null when 2FA off
  twoFactorSecret       String?
  /// bcrypt-hashed backup codes; consumed codes are removed from the array
  twoFactorBackupCodes  String[] @default([])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  ownedWorkspaces  Workspace[]        @relation("WorkspaceOwner")
  memberships      WorkspaceMember[]
  createdTasks     Task[]             @relation("TaskCreator")
  assignedTasks    Task[]             @relation("TaskAssignee")
  comments         Comment[]
  notifications    Notification[]
  attachments      Attachment[]
  refreshTokens    RefreshToken[]
  chatMessages     ChatMessage[]
  notificationPreferences UserNotificationPreference[]
  activities        TaskActivity[]      @relation("UserActivities")
  savedFilters      SavedFilter[]        @relation("SavedFilterOwner")
  chatMessageReads ChatMessageRead[]
  apiKeys          ApiKey[]
  integrations     Integration[] @relation("UserIntegrations")

  @@index([email])
  @@index([deletedAt])
}

model Workspace {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  description String?
  visibility  WorkspaceVisibility @default(PRIVATE)
  ownerId     String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?

  owner   User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members WorkspaceMember[]
  columns Column[]
  tasks   Task[]
  labels  TaskLabel[]
  channels ChatChannel[]                        @relation("WorkspaceChannels")
  notificationSetting WorkspaceNotificationSetting?
  userNotificationPreferences UserNotificationPreference[]
  savedFilters                SavedFilter[]      @relation("SavedFilterWorkspace")
  webhooks                    Webhook[]          @relation("WebhookWorkspaces")
  automationRules             AutomationRule[]   @relation("WorkspaceAutomationRules")
  taskTemplates               TaskTemplate[]     @relation("WorkspaceTaskTemplates")
  sprints                     Sprint[]           @relation("WorkspaceSprints")
  boards                      Board[]            @relation("WorkspaceBoards")
  integrations                Integration[]      @relation("WorkspaceIntegrations")

  @@index([slug])
  @@index([ownerId])
  @@index([deletedAt])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        UserRole @default(MEMBER)
  joinedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
}

model Column {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  position     Int
  color        String?
  isDoneColumn Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([workspaceId])
  @@index([workspaceId, position])
}

enum TaskType {
  TASK
  EPIC
  STORY
  SUBTASK
}

enum SprintStatus {
  PLANNED
  ACTIVE
  CLOSED
}

model Task {
  id           String       @id @default(cuid())
  workspaceId  String
  columnId     String
  parentTaskId String?
  title        String
  description  String?
  priority     TaskPriority @default(MEDIUM)
  status       TaskStatus   @default(TODO)
  type         TaskType     @default(TASK)
  position     Int          @default(0)
  assigneeId   String?
  dueDate      DateTime?
  /// Story points (nullable until estimated)
  estimate     Int?
  sprintId     String?
  boardId      String?
  completedAt  DateTime?
  createdById  String
  version      Int          @default(0)
  labelsDeprecated String[]  @default([])
  searchVector    Unsupported("tsvector")? @map("searchVector")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  column       Column            @relation(fields: [columnId], references: [id], onDelete: Restrict)
  parent       Task?             @relation("TaskParent", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks     Task[]            @relation("TaskParent")
  assignee     User?             @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy    User              @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  sprint       Sprint?           @relation("SprintTasks", fields: [sprintId], references: [id], onDelete: SetNull)
  board        Board?            @relation("BoardTasks", fields: [boardId], references: [id], onDelete: SetNull)
  dependencies TaskDependency[]  @relation("BlockingTask")
  blockers     TaskDependency[]  @relation("BlockedTask")
  comments     Comment[]
  attachments  Attachment[]
  assignments  TaskLabelAssignment[] @relation("TaskAssignments")
  activities   TaskActivity[]        @relation("TaskActivities")

  @@index([workspaceId, deletedAt])
  @@index([columnId])
  @@index([assigneeId])
  @@index([parentTaskId])
  @@index([status])
  @@index([dueDate])
  @@index([sprintId])
  @@index([boardId])
  @@index([type])
  @@index([workspaceId, type])
}

model TaskDependency {
  id              String   @id @default(cuid())
  blockingTaskId  String
  blockedTaskId   String
  createdAt       DateTime @default(now())

  blockingTask Task @relation("BlockingTask", fields: [blockingTaskId], references: [id], onDelete: Cascade)
  blockedTask  Task @relation("BlockedTask", fields: [blockedTaskId], references: [id], onDelete: Cascade)

  @@unique([blockingTaskId, blockedTaskId])
  @@index([blockedTaskId])
}

model TaskActivity {
  id        String         @id @default(cuid())
  taskId    String
  userId    String
  action    ActivityAction
  field     String?
  oldValue  String?
  newValue  String?
  metadata  Json?
  createdAt DateTime       @default(now())

  task Task @relation("TaskActivities", fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("UserActivities", fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[] @relation("WebhookDeliveries")
  ruleExecutions RuleExecution[] @relation("RuleExecutions")

  @@index([taskId, createdAt(sort: Desc)])
  @@index([userId])
}

model TaskLabelAssignment {
  id        String   @id @default(cuid())
  taskId    String
  labelId   String
  createdAt DateTime @default(now())
  deletedAt DateTime?

  task  Task      @relation("TaskAssignments", fields: [taskId], references: [id], onDelete: Cascade)
  label TaskLabel @relation("LabelAssignments", fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@index([taskId])
  @@index([labelId])
}

model TaskLabel {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  version     Int      @default(0)

  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignments TaskLabelAssignment[] @relation("LabelAssignments")

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([deletedAt])
}

model Comment {
  id               String   @id @default(cuid())
  taskId           String
  authorId         String
  parentCommentId  String?
  content          String
  mentionedUserIds String[] @default([])
  isChat           Boolean  @default(false)
  editedAt         DateTime?
  searchVector     Unsupported("tsvector")? @map("searchVector")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  task    Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Restrict)
  parent  Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentReplies")

  @@index([taskId, deletedAt])
  @@index([authorId])
  @@index([parentCommentId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model Attachment {
  id           String         @id @default(cuid())
  taskId       String
  uploadedById String
  filename     String
  mimeType     String
  size         Int
  type         AttachmentType
  searchVector Unsupported("tsvector")? @map("searchVector")
  storagePath  String
  createdAt    DateTime       @default(now())

  task       Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([uploadedById])
}

model SavedFilter {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  name        String
  query       Json
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user      User       @relation("SavedFilterOwner", fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace   @relation("SavedFilterWorkspace", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@index([deletedAt])
  // @@unique([workspaceId, userId, name]) is a partial unique index in the
  // migration (WHERE "deletedAt" IS NULL) — Prisma can't express partial
  // unique indexes, so it's enforced via raw SQL in the migration only.
}

model RefreshToken {
  id        String    @id
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ChatChannel {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation("WorkspaceChannels", fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isPrivate   Boolean  @default(false)
  scope       String   @default("WORKSPACE")
  taskId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  messages    ChatMessage[]      @relation("ChannelMessages")
  // @@unique([workspaceId, name]) is a partial unique index in the
  // migration (WHERE "deletedAt" IS NULL) — Prisma can't express partial
  // unique indexes, so it's enforced via raw SQL in the migration only.
  @@index([workspaceId])
  @@index([taskId])
}

model ChatMessage {
  id              String       @id @default(cuid())
  channelId       String
  channel         ChatChannel  @relation("ChannelMessages", fields: [channelId], references: [id], onDelete: Cascade)
  authorId        String
  author          User         @relation(fields: [authorId], references: [id])
  content         String
  mentionedUserIds String[]
  clientMessageId  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?
  readBy           ChatMessageRead[]
  @@unique([authorId, clientMessageId])
  @@index([channelId, createdAt])
  @@index([authorId])
  @@index([clientMessageId])
}

model ChatMessageRead {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  messageId String
  readAt    DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([channelId])
  @@index([messageId])
}

model WorkspaceNotificationSetting {
  id                   String    @id @default(cuid())
  workspaceId          String    @unique
  workspace            Workspace @relation(fields: [workspaceId], references: [id])
  taskAssignedEmail    Boolean   @default(true)
  taskMentionedEmail   Boolean   @default(true)
  taskDueReminderEmail Boolean   @default(true)
  taskDueReminderHours Int       @default(24)
  commentReplyEmail    Boolean   @default(true)
  commentMentionEmail  Boolean   @default(true)
  dailyDigest          Boolean   @default(false)
  weeklyDigest         Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model UserNotificationPreference {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id])
  workspaceId          String?
  workspace            Workspace? @relation(fields: [workspaceId], references: [id])
  taskAssignedEmail    Boolean?
  taskMentionedEmail   Boolean?
  taskDueReminderEmail Boolean?
  taskDueReminderHours Int?
  dailyDigest          Boolean?
  weeklyDigest         Boolean?
  emailDelayMinutes    Int       @default(0)
  @@unique([userId, workspaceId])
  @@index([userId])
}

model EmailJob {
  id          String   @id @default(cuid())
  userId      String
  type        String
  payload     Json
  status      String   @default("pending")
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  scheduledAt DateTime @default(now())
  completedAt DateTime?
  failedAt    DateTime?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([userId, status])
  @@index([scheduledAt])
}

model Webhook {
  id          String   @id @default(cuid())
  workspaceId String
  url         String
  secret      String
  events      String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  workspace   Workspace          @relation("WebhookWorkspaces", fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]  @relation("WebhookDeliveries")

  @@index([workspaceId, isActive])
  @@index([workspaceId, deletedAt])
}

model WebhookDelivery {
  id            String   @id @default(cuid())
  webhookId     String
  activityId    String
  status        String
  attemptCount  Int      @default(0)
  responseCode  Int?
  responseBody  String?
  deliveredAt   DateTime?
  error         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  webhook  Webhook      @relation("WebhookDeliveries", fields: [webhookId], references: [id], onDelete: Cascade)
  activity TaskActivity @relation("WebhookDeliveries", fields: [activityId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
  @@index([status, createdAt])
}

// --- P2-1 Automation rules ---

model AutomationRule {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  /// ActivityAction value that triggers this rule
  trigger     String
  /// JSON: { field, op, value } condition DSL (null = always)
  condition   Json?
  /// JSON: { type, ...params } action (set-field | assign | move-column | send-webhook | send-email)
  action      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  workspace  Workspace        @relation("WorkspaceAutomationRules", fields: [workspaceId], references: [id], onDelete: Cascade)
  executions RuleExecution[]  @relation("RuleExecutions")

  @@index([workspaceId, isActive])
  @@index([workspaceId, deletedAt])
  @@index([workspaceId, trigger])
}

model RuleExecution {
  id         String   @id @default(cuid())
  ruleId     String
  activityId String
  status     String
  error      String?
  executedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  rule     AutomationRule @relation("RuleExecutions", fields: [ruleId], references: [id], onDelete: Cascade)
  activity TaskActivity   @relation("RuleExecutions", fields: [activityId], references: [id], onDelete: Cascade)

  @@index([ruleId, executedAt])
  @@index([status, executedAt])
}

// --- P3-1 Sprint + estimation ---

model Sprint {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  goal        String?
  startDate   DateTime
  endDate     DateTime
  status      SprintStatus @default(PLANNED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation("WorkspaceSprints", fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]    @relation("SprintTasks")

  @@index([workspaceId, status])
  @@index([workspaceId, deletedAt])
}

// --- P3-2 Templates + recurring ---

model TaskTemplate {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  /// JSON template fields: title, description?, priority?, estimate?, labels?
  fields      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  workspace Workspace       @relation("WorkspaceTaskTemplates", fields: [workspaceId], references: [id], onDelete: Cascade)
  recurring RecurringRule[] @relation("TemplateRecurring")

  @@index([workspaceId, deletedAt])
}

model RecurringRule {
  id         String    @id @default(cuid())
  templateId String
  cron       String
  nextRunAt  DateTime
  lastRunAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  template TaskTemplate @relation("TemplateRecurring", fields: [templateId], references: [id], onDelete: Cascade)

  @@index([isActive, nextRunAt])
  @@index([templateId])
}

// --- P4-2 Multiple boards ---

model Board {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation("WorkspaceBoards", fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]    @relation("BoardTasks")

  @@index([workspaceId])
  @@index([workspaceId, deletedAt])
}

// --- P4-3 Slack + GitLab OAuth integrations ---

enum IntegrationProvider {
  SLACK
  GITLAB
}

model Integration {
  id                  String             @id @default(cuid())
  /// Which OAuth provider issued this token
  provider            IntegrationProvider
  /// Workspace that owns the integration (slack = per workspace, gitlab = per user + workspace)
  workspaceId         String
  /// User that connected it (always present; per-user attribution for gitlab)
  userId              String
  /// Provider's account id (slack team id, gitlab user id)
  externalAccountId   String
  /// Display name (slack team name, gitlab username)
  externalAccountName String
  /// Scopes granted at connect time
  scopes              String[]           @default([])
  /// AES-256-GCM ciphertext of access token (base64: iv.tag.ciphertext)
  accessTokenCipher   String
  /// Optional AES-256-GCM ciphertext of refresh token (gitlab only — slack tokens are long-lived)
  refreshTokenCipher  String?
  /// unix seconds; null = no expiry known
  accessTokenExpiresAt Int?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  workspace Workspace @relation("WorkspaceIntegrations", fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation("UserIntegrations", fields: [userId], references: [id], onDelete: Cascade)

  /// One connection per (provider, workspace, external account). Soft-delete
  /// re-allows the same (provider, workspace, account) — the partial unique
  /// index WHERE "deletedAt" IS NULL is in the migration.
  @@unique([provider, workspaceId, externalAccountId])
  @@index([workspaceId, provider])
  @@index([userId])
  @@index([deletedAt])
}

// --- P4-4 Public API keys ---

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  /// SHA-256 hex of full key (fdkey_…)
  hashedKey  String    @unique
  /// First 8 chars of key for display (fdkey_ab…)
  prefix     String
  lastUsedAt DateTime?
  scopes     String[]  @default([])
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([hashedKey])
}
