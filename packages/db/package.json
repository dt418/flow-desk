{
  "name": "@flowdesk/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./prisma-extension": "./src/prisma-extension.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "DATABASE_URL=postgresql://localhost:5432/flowdesk prisma generate --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^16.6.1",
    "prisma": "^7.8.0",
    "typescript": "^5.4.0"
  }
}
