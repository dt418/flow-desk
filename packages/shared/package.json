{
  "name": "@flow-desk/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Zod schemas and TypeScript types for FlowDesk",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.mjs",
      "require": "./dist/auth.js"
    },
    "./user": {
      "types": "./dist/user.d.ts",
      "import": "./dist/user.mjs",
      "require": "./dist/user.js"
    },
    "./workspace": {
      "types": "./dist/workspace.d.ts",
      "import": "./dist/workspace.mjs",
      "require": "./dist/workspace.js"
    },
    "./task": {
      "types": "./dist/task.d.ts",
      "import": "./dist/task.mjs",
      "require": "./dist/task.js"
    },
    "./comment": {
      "types": "./dist/comment.d.ts",
      "import": "./dist/comment.mjs",
      "require": "./dist/comment.js"
    },
    "./notification": {
      "types": "./dist/notification.d.ts",
      "import": "./dist/notification.mjs",
      "require": "./dist/notification.js"
    },
    "./attachment": {
      "types": "./dist/attachment.d.ts",
      "import": "./dist/attachment.mjs",
      "require": "./dist/attachment.js"
    },
    "./pagination": {
      "types": "./dist/pagination.d.ts",
      "import": "./dist/pagination.mjs",
      "require": "./dist/pagination.js"
    },
    "./common": {
      "types": "./dist/common.d.ts",
      "import": "./dist/common.mjs",
      "require": "./dist/common.js"
    },
    "./label": {
      "types": "./dist/label.d.ts",
      "import": "./dist/label.mjs",
      "require": "./dist/label.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'shared: lint placeholder'",
    "test": "pnpm exec vitest run",
    "test:watch": "pnpm exec vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsup": "^8.3.5",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  }
}
