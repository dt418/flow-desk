{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": false,
    "sourceMap": true,
    "types": ["node"],
    "paths": {
      "@flowdesk/db": ["../../packages/db/src"],
      "@flowdesk/db/*": ["../../packages/db/src/*"],
      "@flowdesk/env": ["../../packages/env/src"],
      "@flowdesk/env/*": ["../../packages/env/src/*"]
    }
  },
  "include": ["src/**/*", "generated/**/*", "../../packages/db/generated/**/*", "../../packages/db/src/**/*", "../../packages/env/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
