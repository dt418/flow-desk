{
  "name": "@flow-desk/api",
  "version": "0.1.0",
  "private": true,
  "description": "FlowDesk API — Hono + Node.js + Prisma",
  "scripts": {
    "dev": "tsx watch --include='../../packages/shared/dist/**/*.js' src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'api: lint placeholder'",
    "test": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "prisma": "prisma",
    "db:generate": "bash ../../scripts/prisma-exec.sh generate",
    "db:migrate": "bash ../../scripts/prisma-exec.sh migrate dev",
    "db:migrate-deploy": "bash ../../scripts/prisma-exec.sh migrate deploy",
    "db:seed": "bash ../../scripts/prisma-exec.sh seed",
    "db:studio": "bash ../../scripts/prisma-exec.sh studio",
    "db:push": "bash ../../scripts/prisma-exec.sh db push",
    "db:push-skip-generate": "bash ../../scripts/prisma-exec.sh db push --skip-generate",
    "db:reset": "bash ../../scripts/prisma-exec.sh db push --force-reset --accept-data-loss --skip-generate"
  },
  "dependencies": {
    "@flow-desk/shared": "workspace:*",
    "@flowdesk/db": "workspace:*",
    "@flowdesk/env": "workspace:*",
    "@hono/node-server": "^1.13.2",
    "@hono/zod-validator": "^0.8.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "cookie": "^1.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "google-auth-library": "^9.14.1",
    "hono": "^4.5.10",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "rate-limiter-flexible": "^5.0.4",
    "socket.io": "^4.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.0",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  }
}
